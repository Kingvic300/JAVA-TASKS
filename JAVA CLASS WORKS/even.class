public class PatternTriangle{

	public static void main(String[] args){

	for( int count = 1; count <= 5; count++){

		for(int counter = 1; inner <= counter; counter++){

			System.out.print(counter+ " ");

		}System.out.println();

	}



	for(int count = 1; count<=5; count++){

		for(int counter = 5;counter >=count; counter--){

			System.out.print(counter+ " ");

		}System.out.println();


	}

	}


}